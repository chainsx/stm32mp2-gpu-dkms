#!/bin/sh
set -eu
libdir='@LIBDIR@'
status=0

fail() {
    echo "error: $*" >&2
    status=1
}

check_provider() {
    stem="$1"
    candidate="$(find "$libdir" -maxdepth 1 -type f -name "${stem}.so.*" -print | LC_ALL=C sort -V | head -n 1 || true)"
    if [ -z "$candidate" ]; then
        fail "missing GCNANO ${stem} runtime below ${libdir}"
        return
    fi
    resolved="$(ldconfig -p 2>/dev/null | awk -v stem="$stem" '$1 ~ ("^" stem "\\.so") {print $NF; exit}')"
    case "$resolved" in
        "$libdir"/*) echo "${stem}: ${resolved}" ;;
        *) fail "${stem}: expected provider under ${libdir}, got ${resolved:-not-found}" ;;
    esac
}

check_required_file() {
    name="$1"
    purpose="$2"
    if [ -f "$libdir/$name" ]; then
        echo "${name}: ${purpose}"
    else
        fail "missing ${name} (${purpose}) below ${libdir}"
    fi
}

# libGAL/libVSC are the vendor core. GLSLC is required by the default GLES/VG
# feature closure in the ST recipe, and gbm_viv is the vendor GBM backend.
check_required_file libGAL.so 'Vivante vendor core'
check_required_file libVSC.so 'Vivante vendor support core'
check_required_file libGLSLC.so 'GLES/OpenVG shader compiler support'
check_required_file libgbm_viv.so 'Vivante GBM backend'
check_provider libEGL
check_provider libgbm
check_provider libGLESv1_CM
check_provider libGLESv2
check_provider libOpenVG
exit "$status"
